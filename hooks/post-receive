#!/bin/bash
# Set umask so group always gets write permissions
umask 0002

APPNAME="${PWD##*/}"
APPNAME="${APPNAME%.git}"
REPO_PATH="$PWD"
VERSION=$(git rev-parse --short HEAD)
WORK_DIR="/tmp/build-${VERSION}"

echo "🎯 Git Hook: Post-Receive Deployment"
echo "====================================="
echo "Repository: ${APPNAME}"
echo "Version: ${VERSION}"
echo "Checkout to: ${WORK_DIR}"
echo ""

if ! git clone --depth=1 "file://${REPO_PATH}" "$WORK_DIR" 2>&1; then
  echo "❌ Failed to clone repository"
  exit 1
fi

cd "$WORK_DIR" || exit 1

# Determine APP_DIR from project.json owner or fall back to flat structure
OWNER=""
if [ -f "project.json" ]; then
  OWNER=$(grep -o '"owner"[[:space:]]*:[[:space:]]*"[^"]*"' project.json | head -1 | sed 's/.*"owner"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
fi

if [ -n "$OWNER" ]; then
  APP_DIR="/var/apps/${OWNER}/${APPNAME}"
else
  APP_DIR="/var/apps/${APPNAME}"
fi

echo "📁 Workspace: ${APP_DIR}"

# Debug: Show current directory and files
echo "📋 Current directory: $(pwd)"
echo "📋 Files in directory:"
ls -la

# Check if Dockerfile exists and build if present
HAS_DOCKERFILE=false
if [ -f "Dockerfile" ]; then
  HAS_DOCKERFILE=true
  echo "🔨 Building Docker image..."
  # Disable BuildKit git detection for cloned repos
  export DOCKER_BUILDKIT=1
  if docker build --no-cache -t "${APPNAME}:${VERSION}" -t "${APPNAME}:latest" . 2>&1; then
    echo "✅ Build successful (tagged as ${APPNAME}:${VERSION} and ${APPNAME}:latest)"
  else
    echo "⚠️  Build failed - will use existing or pre-built images"
  fi
  echo ""
else
  echo "⚠️  No Dockerfile found - skipping build"
  echo "   Using pre-built images from compose.yaml"
  echo ""
fi

echo "🚀 Deploying stack to Docker Swarm..."

if [ ! -f "compose.yaml" ]; then
  echo "❌ compose.yaml not found"
  cd / && rm -rf "$WORK_DIR"
  exit 1
fi

# Copy config files to workspace
mkdir -p "$APP_DIR"
# Set group ownership and setgid bit for group inheritance
DOCKER_GID=${DOCKER_GID:-999}
chgrp docker "$APP_DIR" 2>/dev/null || chgrp "$DOCKER_GID" "$APP_DIR" 2>/dev/null || true
chmod 2775 "$APP_DIR" 2>/dev/null || true

# Ensure data directory exists with correct permissions
mkdir -p "$APP_DIR/data"
chgrp docker "$APP_DIR/data" 2>/dev/null || chgrp "$DOCKER_GID" "$APP_DIR/data" 2>/dev/null || true
chmod 2775 "$APP_DIR/data" 2>/dev/null || true

cp compose.yaml "$APP_DIR/compose.yaml"
[ -f project.json ] && cp project.json "$APP_DIR/project.json"

# Regenerate Kong config if project.json changed
if [ -f project.json ]; then
  echo "🔄 Regenerating Kong configuration..."
  SWARM_CONFIG_DIR="/var/apps/swarm-config"
  if [ -d "$SWARM_CONFIG_DIR" ]; then
    cd "$SWARM_CONFIG_DIR" || exit 1
    if npm run kong:generate 2>&1; then
      echo "✅ Kong config regenerated"
      if npm run kong:reload 2>&1; then
        echo "✅ Kong reloaded"
      else
        echo "⚠️  Kong reload failed (config may be invalid)"
      fi
    else
      echo "⚠️  Kong config generation failed"
    fi
    cd "$APP_DIR" || exit 1
  else
    echo "⚠️  Swarm config directory not found, skipping Kong update"
  fi
fi

cd "$APP_DIR" || exit 1
export VERSION

# Ensure .env exists (create empty if missing)
if [ ! -f ".env" ]; then
  touch .env
  echo "📝 Created empty .env file"
fi

# Load and export all variables from .env for Docker Swarm variable substitution
if [ -f ".env" ]; then
  echo "📝 Loading environment variables from .env"
  set -a  # automatically export all variables
  source .env
  set +a
fi

# Ensure DOCKER_GID is set (fallback to default if not in .env)
export DOCKER_GID=${DOCKER_GID:-999}

# Use 'changed' strategy to:
# - Use locally built images when available (newer)
# - Pull external images (postgres, redis, etc.) when needed
echo "📦 Deploying with image resolution strategy: changed"

if docker stack deploy --detach=true --with-registry-auth --resolve-image changed -c compose.yaml "$APPNAME"; then
  echo "✅ Stack deployed successfully"
  
  # Force update all services to pull latest images and restart
  echo ""
  echo "🔄 Updating services to pull latest images..."
  SERVICES=$(docker stack services "$APPNAME" --format "{{.Name}}")
  if [ -n "$SERVICES" ]; then
    echo "$SERVICES" | while read -r service; do
      echo "  → Updating $service"
      docker service update --force --with-registry-auth "$service" > /dev/null 2>&1
    done
    echo "✅ All services updated"
  fi
  
  # Execute post-deploy hook if it exists
  if [ -f "$WORK_DIR/post-deploy.sh" ]; then
    echo ""
    echo "🎬 Executing post-deploy hook..."
    
    # Ensure script is executable
    chmod +x "$WORK_DIR/post-deploy.sh"
    
    # Copy to APP_DIR so it can find other scripts
    cp "$WORK_DIR/post-deploy.sh" "$APP_DIR/post-deploy.sh" 2>/dev/null || true
    
    # Run in background so deployment doesn't block
    cd "$APP_DIR" && nohup ./post-deploy.sh > post-deploy.log 2>&1 &
    
    echo "✅ Post-deploy hook started (check $APP_DIR/post-deploy.log for output)"
  fi
  
  cd / && rm -rf "$WORK_DIR"
  exit 0
else
  echo "❌ Deployment failed"
  cd / && rm -rf "$WORK_DIR"
  exit 1
fi
